{
  "name": "let-it-ride-app-store-screenshots",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "test": "tsx --test scripts/*.test.ts",
    "export:iphone": "tsx scripts/export-playwright.ts --url http://127.0.0.1:3000 --width 1242 --height 2688 --out exports/app-store-screenshots --locale en-US --device iphone-6.5 --theme shibuya-red",
    "validate": "tsx scripts/validate-exports.ts --dir exports/app-store-screenshots/screenshots --allow 1242x2688 --output exports/app-store-screenshots/_validation.txt"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "next": "^15.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "playwright": "^1.54.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
