# ESP32-S3 Configuration for IceNav
CONFIG_IDF_TARGET="esp32s3"

# WiFi Configuration
CONFIG_ESP32_WIFI_ENABLED=y
CONFIG_ESP_WIFI_ENABLED=y

# Bluetooth Configuration
CONFIG_BT_ENABLED=y
CONFIG_BTDM_CTRL_MODE_BLE_ONLY=y

# PSRAM Configuration
CONFIG_ESP32S3_SPIRAM_SUPPORT=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# Flash Configuration
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# USB Configuration
CONFIG_TINYUSB_ENABLED=y
CONFIG_TINYUSB_CDC_ENABLED=y

# FreeRTOS Configuration
CONFIG_FREERTOS_UNICORE=n

# Arduino Configuration
CONFIG_ARDUINO_ISR_IRAM_SAFE=y

# VFS and File I/O Configuration (required for 4+ map blocks)
CONFIG_VFS_SUPPORT_IO=y
CONFIG_VFS_SUPPORT_DIR=y
CONFIG_VFS_SUPPORT_SELECT=y
CONFIG_NEWLIB_STDIN_LINE_ENDING_LF=y
CONFIG_NEWLIB_STDOUT_LINE_ENDING_CRLF=y

# Increase FreeRTOS semaphore/mutex resources for file operations
CONFIG_FREERTOS_ENABLE_STATIC_TASK_CLEAN_UP=y
